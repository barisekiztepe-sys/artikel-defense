{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "highScore": { "type": "number" },
        "streak": { "type": "number" },
        "unlockedCards": { "type": "array", "items": { "type": "string" } },
        "unlockedStage": { "type": "number" },
        "credits": { "type": "number" }
      },
      "required": ["uid", "displayName", "highScore"]
    },
    "Score": {
      "title": "Score",
      "description": "Global leaderboard entry",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "score": { "type": "number" },
        "mode": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "score", "mode", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Private user data"
    },
    "/leaderboard/{scoreId}": {
      "schema": "Score",
      "description": "Public high scores"
    }
  }
}
