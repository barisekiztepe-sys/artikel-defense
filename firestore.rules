rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'highScore']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.highScore is number &&
             (!('streak' in data) || data.streak is number) &&
             (!('unlockedCards' in data) || data.unlockedCards is list) &&
             (!('unlockedStage' in data) || data.unlockedStage is number) &&
             (!('credits' in data) || data.credits is number);
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'displayName', 'score', 'mode', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.score is number &&
             data.mode in ['STORY', 'ENDLESS', 'PLURAL', 'VERBS', 'VOCAB', 'REVENGE'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /leaderboard/{scoreId} {
      allow read: if true; // Public leaderboard
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update: if false; // Scores are immutable
      allow delete: if false;
    }
  }
}
